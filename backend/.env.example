# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/quizzie_db

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave SMTP_USERNAME blank to skip sending (tokens print to console instead).
# Gmail setup: enable 2FA → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Quizzie
