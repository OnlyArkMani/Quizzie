# ── Quizzie — Production Environment Variables ─────────────────────────────
# Copy this to backend/.env and fill in real values before deploying.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/quizzie_db

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your deployed frontend URL)
CORS_ORIGINS=https://your-app.onrender.com,https://your-custom-domain.com

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
FRONTEND_URL=https://your-app.onrender.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# For Gmail: enable 2FA → create an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=your-gmail@gmail.com
EMAIL_FROM_NAME=Quizzie

# ── Docker Compose DB credentials (root-level .env) ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=quizzie_db
